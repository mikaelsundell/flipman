QMainWindow,
QDialog
{
    color: $color.text;
    font-size: $font.size.medium;
    background-color: $color.base;
}

QMainWindow::separator {
    background: $color.basealt;
    width: 6px;
}

QCheckBox {
    color: $color.text;
    font-size: $font.size.medium;
    spacing: 8px;
    padding-right: 10px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    background-color: $color.basealt;
    border: 1px solid $color.border;
}

QCheckBox::indicator:checked {
    image: url("$icon.checked");
}

QCheckBox::indicator:indeterminate {
    image: url("$icon.partiallychecked");
}

QComboBox,
QLineEdit,
QPushButton,
QToolButton,
QSpinBox,
QLabel,
QDoubleSpinBox
{
    min-height: 24px;
    border: 1px solid $color.border;
    border-radius: 0px;
}

QLineEdit
{
    font-size: $font.size.medium;
    selection-background-color: $color.highlight;
    min-width: 50px;
    padding: 2px 6px;
}

QComboBox {
    font-size: $font.size.medium;
    min-width: 50px;
    background-color: $color.basealt;
    border: 1px solid $color.border;
    min-height: 24px;
    max-height: 24px;
    padding: 2px 24px 2px 10px;
    margin: 0px;
    outline: none;
}

QComboBox:disabled {
    color: $color.text.disabled;
}

QComboBox::down-arrow {
    image: url("$icon.down");
    width: 10px;
    height: 10px;
}

QComboBox::drop-down {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 22px;
    border: 0px;
}

QComboBox::item {
    color: $color.text;
    height: 10px;
    background-color: $color.basealt;
    border: 8px solid transparent;
}

QComboBox::item:selected {
    background: $color.highlight;
}

QPushButton
{
    font-size: $font.size.medium;
    background-color: $color.button;
    min-width: 50px;
    padding: 2px 8px;
}

QPushButton:default
{
    font-weight: bold;
}

QPushButton:disabled
{
    color: $color.text.disabled;
}

QPushButton:pressed
{
    background-color: $color.button.lightness(90);
}

QToolButton
{
    background-color: $color.button;
    padding: 2px 8px;
}

QToolButton:default
{
    font-weight: bold;
}

QToolButton:disabled
{
    color: $color.text.disabled;
}

QToolButton:checked
{
    background-color: $color.button.lightness(160);
}

QToolButton:pressed
{
    background-color: $color.button.lightness(80);
}

QToolButton[popupMode="1"]
{
    padding-right: 18px;
}

QToolButton::menu-button
{
    subcontrol-origin: border;
    subcontrol-position: center right;
    width: 18px;
    border: 0px;
    background: transparent;
}

QToolButton::menu-arrow
{
    width: 10px;
    height: 10px;
    image: url("$icon.down");
}

QToolButton::menu-arrow:open
{
    width: 10px;
    height: 10px;
    image: url("$icon.up");
}

QSpinBox,
QDoubleSpinBox
{
    font-size: $font.size.medium;
    background-color: $color.basealt;
    selection-background-color: $color.highlight;
    padding-left: 8px;
    padding-right: 24px;
}

QSpinBox::up-button,
QDoubleSpinBox::up-button
{
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 18px;
    height: 11px;
    right: 2px;
    top: 1px;
    border: 0px;
    background: transparent;
}

QSpinBox::down-button,
QDoubleSpinBox::down-button
{
    subcontrol-origin: padding;
    subcontrol-position: bottom right;
    width: 18px;
    height: 11px;
    right: 2px;
    bottom: 1px;
    border: 0px;
    background: transparent;
}

QSpinBox::up-arrow,
QDoubleSpinBox::up-arrow
{
    width: 8px;
    height: 8px;
    image: url("$icon.up");
}

QSpinBox::down-arrow,
QDoubleSpinBox::down-arrow
{
    width: 8px;
    height: 8px;
    image: url("$icon.down");
}

QDockWidget {
    background: $color.dock;
}

QFrame {
    border: 0px solid $color.border;
}

QGroupBox
{
    color: $color.text;
    font-size: $font.size.medium;
    background-color: $color.base;
    border: 1px solid $color.border;
    margin-top: 10px;
    padding-top: 12px;
}

QGroupBox::title
{
    subcontrol-origin: margin;
    subcontrol-position: top left;
    color: $color.text;
    padding: 0px 6px;
    left: 8px;
    background-color: $color.base;
}

QLabel
{
    font-size: $font.size.medium;
    color: $color.text;
    border: 0px;
}

QListWidget {
    color: $color.text;
    background-color: $color.basealt;
    border: 1px solid $color.border;
    outline: none;
    padding: 0px;
}

QListWidget::item {
    color: $color.text;
    background-color: $color.basealt;
    border: 1px solid $color.border;
    margin: 4px;
    padding: 0px;
}

QListWidget::item:selected {
    color: $color.text;
    background-color: $color.highlight;
}

QMenuBar {
    background-color: $color.base;
    color: $color.text;
    border: 0px;
    spacing: 0px;
    padding: 2px;
}

QMenuBar::item {
    background: transparent;
    color: $color.text;
    padding: 6px 12px;
    margin: 0px;
}

QMenuBar::item:selected {
    background-color: $color.highlight;
    color: $color.text;
}

QMenuBar::item:pressed {
    background-color: $color.highlight;
    color: $color.text;
}

QMenu {
    background-color: $color.basealt;
    border: 0px solid $color.border;
    padding: 4px;
}

QMenu::item {
    color: $color.text;
    font-size: $font.size.medium;
    background-color: transparent;
    padding: 4px 20px 4px 20px;
}

QMenu::item:selected {
    background-color: $color.highlight;
}

QMenu::separator {
    height: 1px;
    margin: 4px 4px;
    background-color: $color.borderalt;
}

QMenu::indicator {
    width: 16px;
    height: 16px;
}

QMenu::indicator:checked {
    image: url("$icon.checked");
}

QMenu::indicator:indeterminate {
    image: url("$icon.partiallychecked");
}

QMenu::indicator:unchecked {
    image: none;
}

QMenu::right-arrow {
    width: 16px;
    height: 16px;
    image: url("$icon.right");
}

QMenu::left-arrow {
    width: 16px;
    height: 16px;
    image: url("$icon.left");
}

QProgressBar {
    min-height: 10px;
    max-height: 10px;
    border-radius: 4px;
    background-color: $color.basealt;
    color: $color.text;
}

QProgressBar::chunk {
    border-radius: 4px;
    background-color: $color.progress;
}

QPlainTextEdit
{
    font-family: "Menlo", "Consolas", "Courier New", monospace;
    font-size: $font.size.medium;
    color: $color.text;
    background-color: $color.basealt;
    selection-background-color: $color.highlight;
    selection-color: $color.text;
    border: 1px solid $color.border;
    outline: none;
    padding: 6px;
}

QPlainTextEdit:disabled
{
    color: $color.text.disabled;
    background-color: $color.basealt;
    selection-background-color: $color.basealt;
    selection-color: $color.text.disabled;
}

QScrollArea
{
    background-color: $color.base;
    border: 0px;
}

QScrollArea > QWidget > QWidget
{
    background-color: $color.base;
}

QScrollBar:horizontal {
    background: $color.basealt;
    height: 16px;
    margin: 0;
    border: none;
}

QScrollBar::handle:horizontal {
    background: $color.handle;
    min-width: 20px;
    border-radius: 4px;
    margin: 4px 4px;
}

QScrollBar::handle:horizontal:hover {
    background: $color.handle;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    background: none;
    width: 0;
}

QScrollBar::left-arrow:horizontal,
QScrollBar::right-arrow:horizontal {
    background: none;
    width: 0;
    height: 0;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: none;
}

QScrollBar:vertical {
    background: $color.basealt;
    width: 16px;
    margin: 0;
    border: none;
}

QScrollBar::handle:vertical {
    background: $color.handle;
    min-height: 20px;
    border-radius: 4px;
    margin: 4px 4px;
}

QScrollBar::handle:vertical:hover {
    background: $color.handle;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    background: none;
    height: 0;
}

QScrollBar::up-arrow:vertical,
QScrollBar::down-arrow:vertical {
    background: none;
    width: 0;
    height: 0;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
}

QAbstractScrollArea::corner {
    background: $color.basealt;
}

QSplitter
{
    border: 0px;
}

QSplitter::handle {
    background-color: $color.dock;
    height: 5px;
}

QStatusBar {
    font-size: $font.size.medium;
    color: $color.text;
    background: $color.dock;
}

QTabWidget::pane
{
    background-color: $color.item;
    border-left: 1px solid $color.border;
    border-right: 1px solid $color.border;
    border-bottom: 1px solid $color.border;
    border-top: 0px;
    top: 0px;
}

QTabWidget::tab-bar
{
    alignment: left;
}

QTabBar
{
    background: $color.itemalt;
}

QTabBar::tab
{
    font-size: $font.size.medium;
    color: $color.text;
    background-color: $color.itemalt;
    border-top: 1px solid $color.border;
    border-left: 1px solid $color.border;
    border-right: 1px solid $color.border;
    border-bottom: 1px solid $color.border;
    padding: 4px 8px;
    margin: 0px;
    margin-right: -1px;
    min-width: 60px;
}

QTabBar::tab:selected
{
    color: $color.text;
    background-color: $color.item;
    border-bottom-color: $color.item;
}

QTabBar::tab:!selected
{
    color: $color.text;
    background-color: $color.itemalt;
}

QTabBar::tab:hover:!selected
{
    background-color: $color.item;
}

QTabBar QToolButton
{
    color: $color.text;
    background-color: $color.itemalt;
    border: 1px solid $color.border;
    padding: 0px;
    margin: 0px;
    min-width: 22px;
    max-width: 22px;
    min-height: 34px;
    max-height: 34px;
}

QTabBar QToolButton:hover,
QTabBar QToolButton:pressed
{
    background-color: $color.item;
}

QTabBar QToolButton::menu-indicator
{
    image: none;
}

QTextBrowser
{
    font-size: $font.size.medium;
    color: $color.text;
    background-color: $color.basealt;
    selection-background-color: $color.highlight;
    alternate-background-color: $color.basealt;
}

QTextEdit
{
    font-family: "Menlo", "Consolas", "Courier New", monospace;
    font-size: $font.size.medium;
    color: $color.text;
    background-color: $color.basealt;
    selection-background-color: $color.highlight;
    selection-color: $color.text;
    border: 1px solid $color.border;
    outline: none;
    padding: 6px;
}

QTextEdit:disabled
{
    color: $color.text.disabled;
    background-color: $color.basealt;
    selection-background-color: $color.basealt;
    selection-color: $color.text.disabled;
}

QSlider {
    background: transparent;
}

QSlider::groove:horizontal {
    height: 4px;
    border: 1px solid $color.border;
    border-radius: 4px;
    background: $color.basealt;
}

QSlider::handle:horizontal {
    width: 8px;
    background: $color.handle;
    border-radius: 4px;
    margin: -5px 0;
}

QTableView
{
    color: $color.text;
    font-size: $font.size.medium;
    outline: none;
    border: 1px solid $color.border;
    background-color: $color.item;
    selection-background-color: $color.highlight;
    gridline-color: $color.borderalt;
}

QTableView QHeaderView
{
    background-color: $color.basealt;
    border: none;
}

QTableView QHeaderView::section
{
    color: $color.text;
    background-color: $color.basealt;
    border: none;
    padding: 4px 6px;
}

QTableView::item
{
    height: 28px;
    color: $color.text;
    background-color: $color.item;
    selection-background-color: $color.highlight;
}

QHeaderView
{
    background-color: $color.basealt;
    border: none;
}

QHeaderView::section
{
    color: $color.text;
    background-color: $color.basealt;
    border: none;
    padding: 4px 6px;
}

QTreeView
{
    color: $color.text;
    font-size: $font.size.medium;
    outline: none;
    border: 1px solid $color.border;
    background-color: $color.item;
    alternate-background-color: $color.itemalt;
    selection-background-color: $color.highlight;
}

QTreeView::item {
    height: 28px;
    color: $color.text;
    background-color: $color.item;
    selection-background-color: $color.highlight;
}

QTreeView::item:alternate {
    background-color: $color.itemalt;
}

QTreeView::item:selected {
    color: $color.text;
    background-color: $color.highlight;
}

QTreeView QHeaderView
{
    background-color: $color.basealt;
    border: none;
    font-size: $font.size.medium;
}

QTreeView QHeaderView:section
{
    color: $color.text;
    background-color: $color.basealt;
    border: none;
    padding: 4px 6px;
}

QTreeView::indicator {
    width: 18px;
    height: 18px;
    background-color: $color.basealt;
    border: 1px solid $color.border;
}

QTreeView::indicator:checked {
    image: url("$icon.checked");
}

QTreeView::indicator:unchecked {
    image: none;
}

QTreeView::indicator:indeterminate {
    image: url("$icon.partiallychecked");
}